---
---
<div id="secretDashboard" style="display:none; position:fixed; inset:0; background:#000; z-index:99999; overflow-y:auto;">

  <!-- PIN Screen -->
  <div id="pinScreen" style="display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:100vh; font-family:monospace;">
    <div style="text-align:center; padding:2rem;">
      <div style="font-size:3rem; margin-bottom:1rem;">🕵️</div>
      <h2 style="color:#00ff00; font-size:1.5rem; margin-bottom:0.5rem;">CLASSIFIED</h2>
      <p style="color:#94a3b8; font-size:0.8rem; margin-bottom:2rem;">Enter PIN to access</p>
      <div id="pinDisplay" style="color:#00ff00; font-size:2rem; letter-spacing:0.5rem; margin-bottom:2rem; min-height:2.5rem;">______</div>
      <div style="display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; max-width:240px; margin:0 auto;">
        <button class="pin-btn" data-num="1">1</button>
        <button class="pin-btn" data-num="2">2</button>
        <button class="pin-btn" data-num="3">3</button>
        <button class="pin-btn" data-num="4">4</button>
        <button class="pin-btn" data-num="5">5</button>
        <button class="pin-btn" data-num="6">6</button>
        <button class="pin-btn" data-num="7">7</button>
        <button class="pin-btn" data-num="8">8</button>
        <button class="pin-btn" data-num="9">9</button>
        <button class="pin-btn" data-num="clear" style="background:#dc2626;">✕</button>
        <button class="pin-btn" data-num="0">0</button>
        <button class="pin-btn" data-num="enter" style="background:#16a34a;">✓</button>
      </div>
      <p id="pinError" style="color:#dc2626; margin-top:1rem; display:none;">Wrong PIN!</p>
    </div>
  </div>

  <!-- FRIEND Chat Only View -->
  <div id="friendContent" style="display:none; padding:1.5rem; max-width:600px; margin:0 auto;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:2rem; border-bottom:1px solid rgba(0,255,0,0.2); padding-bottom:1rem;">
      <h1 style="color:#00ff00; font-family:monospace; font-size:1.2rem;">💬 Secure Chat</h1>
      <button id="closeFriend" style="background:transparent; border:1px solid #dc2626; color:#dc2626; padding:0.5rem 1rem; border-radius:8px; cursor:pointer; font-family:monospace;">EXIT</button>
    </div>
    <div id="friendChatMessages" style="height:400px; overflow-y:auto; background:#0a0a0a; border:1px solid rgba(0,255,0,0.2); border-radius:12px; padding:1rem; margin-bottom:1rem; font-family:monospace;">
      <p style="color:#94a3b8; font-size:0.8rem; text-align:center;">Loading messages...</p>
    </div>
    <div style="display:flex; gap:0.5rem; align-items:flex-end;">
      <div style="flex:1;">
        <input id="friendSender" type="text" placeholder="Your name" style="width:100%; background:#0a0a0a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.6rem; border-radius:8px; font-family:monospace; font-size:0.85rem; margin-bottom:0.5rem; box-sizing:border-box;" />
        <textarea id="friendInput" placeholder="Type a message..." rows="2" style="width:100%; background:#0a0a0a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.6rem; border-radius:8px; font-family:monospace; font-size:0.85rem; resize:none; box-sizing:border-box;"></textarea>
      </div>
      <div style="display:flex; flex-direction:column; gap:0.5rem;">
        <button id="sendFriendChat" style="background:#2563eb; color:#fff; border:none; padding:0.75rem 1rem; border-radius:8px; cursor:pointer; font-family:monospace;">Send 📤</button>
        <label style="background:#0a0a0a; border:1px solid rgba(255,255,255,0.2); color:#94a3b8; padding:0.75rem 1rem; border-radius:8px; cursor:pointer; font-family:monospace; text-align:center;">
          📎
          <input type="file" id="friendImage" accept="image/*" style="display:none;" />
        </label>
      </div>
    </div>
    <div id="friendImagePreview" style="display:none; margin-top:0.5rem;">
      <img id="friendPreviewImg" style="max-height:100px; border-radius:8px; border:1px solid rgba(255,255,255,0.2);" />
      <button onclick="clearFriendImagePreview()" style="background:transparent; border:none; color:#dc2626; cursor:pointer; font-size:1.2rem; margin-left:0.5rem;">✕</button>
    </div>
  </div>

  <!-- ADMIN Full Dashboard -->
  <div id="dashboardContent" style="display:none; padding:1.5rem; max-width:600px; margin:0 auto;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:2rem; border-bottom:1px solid rgba(0,255,0,0.2); padding-bottom:1rem;">
      <h1 style="color:#00ff00; font-family:monospace; font-size:1.2rem;">🕵️ HQ</h1>
      <button id="closeDashboard" style="background:transparent; border:1px solid #dc2626; color:#dc2626; padding:0.5rem 1rem; border-radius:8px; cursor:pointer; font-family:monospace;">EXIT</button>
    </div>

    <div style="display:flex; gap:0.5rem; margin-bottom:2rem; flex-wrap:wrap;">
      <button class="tab-btn active-tab" data-tab="notes">📝 Notes</button>
      <button class="tab-btn" data-tab="chat">💬 Chat</button>
      <button class="tab-btn" data-tab="photos">📸 Photos</button>
      <button class="tab-btn" data-tab="visitors">👥 Visitors</button>
      <button class="tab-btn" data-tab="reviews">🗑️ Reviews</button>
    </div>

    <!-- NOTES -->
    <div id="tab-notes" class="tab-content">
      <textarea id="noteInput" placeholder="Write a private note..." style="width:100%; height:120px; background:#0a0a0a; border:1px solid rgba(0,255,0,0.3); color:#fff; padding:1rem; border-radius:12px; font-family:monospace; font-size:0.9rem; resize:none; margin-bottom:1rem; box-sizing:border-box;"></textarea>
      <button id="saveNote" style="background:#16a34a; color:#fff; border:none; padding:0.75rem 2rem; border-radius:9999px; cursor:pointer; font-family:monospace; margin-bottom:2rem;">Save Note</button>
      <div id="notesList"></div>
    </div>

    <!-- CHAT -->
    <div id="tab-chat" class="tab-content" style="display:none;">
      <div id="chatMessages" style="height:350px; overflow-y:auto; background:#0a0a0a; border:1px solid rgba(0,255,0,0.2); border-radius:12px; padding:1rem; margin-bottom:1rem; font-family:monospace;">
        <p style="color:#94a3b8; font-size:0.8rem; text-align:center;">Loading messages...</p>
      </div>
      <div style="display:flex; gap:0.5rem; align-items:flex-end;">
        <div style="flex:1;">
          <input id="chatSender" type="text" placeholder="Your name" style="width:100%; background:#0a0a0a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.6rem; border-radius:8px; font-family:monospace; font-size:0.85rem; margin-bottom:0.5rem; box-sizing:border-box;" />
          <textarea id="chatInput" placeholder="Type a message..." rows="2" style="width:100%; background:#0a0a0a; border:1px solid rgba(255,255,255,0.1); color:#fff; padding:0.6rem; border-radius:8px; font-family:monospace; font-size:0.85rem; resize:none; box-sizing:border-box;"></textarea>
        </div>
        <div style="display:flex; flex-direction:column; gap:0.5rem;">
          <button id="sendChat" style="background:#2563eb; color:#fff; border:none; padding:0.75rem 1rem; border-radius:8px; cursor:pointer; font-family:monospace; white-space:nowrap;">Send 📤</button>
          <label style="background:#0a0a0a; border:1px solid rgba(255,255,255,0.2); color:#94a3b8; padding:0.75rem 1rem; border-radius:8px; cursor:pointer; font-family:monospace; text-align:center; white-space:nowrap;">
            📎
            <input type="file" id="chatImage" accept="image/*" style="display:none;" />
          </label>
        </div>
      </div>
      <div id="imagePreview" style="display:none; margin-top:0.5rem;">
        <img id="previewImg" style="max-height:100px; border-radius:8px; border:1px solid rgba(255,255,255,0.2);" />
        <button onclick="clearImagePreview()" style="background:transparent; border:none; color:#dc2626; cursor:pointer; font-size:1.2rem; margin-left:0.5rem;">✕</button>
      </div>
      <button id="clearChat" style="margin-top:1rem; background:transparent; border:1px solid #dc2626; color:#dc2626; padding:0.4rem 1rem; border-radius:8px; cursor:pointer; font-family:monospace; font-size:0.75rem;">Clear All Messages</button>
    </div>

    <!-- PHOTOS -->
    <div id="tab-photos" class="tab-content" style="display:none;">
      <label style="display:block; background:#0a0a0a; border:2px dashed rgba(0,255,0,0.3); color:#94a3b8; padding:2rem; border-radius:12px; text-align:center; cursor:pointer; font-family:monospace; margin-bottom:1.5rem;">
        📸 Tap to upload photo
        <input type="file" id="photoUpload" accept="image/*" style="display:none;" />
      </label>
      <p id="uploadStatus" style="color:#00ff00; font-family:monospace; font-size:0.8rem; margin-bottom:1rem; display:none;"></p>
      <div id="photoGrid" style="display:grid; grid-template-columns:repeat(2,1fr); gap:1rem;"></div>
    </div>

    <!-- VISITORS -->
    <div id="tab-visitors" class="tab-content" style="display:none;">
      <div id="visitorsList"><p style="color:#94a3b8; font-family:monospace;">Loading visitors...</p></div>
    </div>

    <!-- REVIEWS -->
    <div id="tab-reviews" class="tab-content" style="display:none;">
      <div id="adminReviewsList"><p style="color:#94a3b8; font-family:monospace;">Loading reviews...</p></div>
    </div>
  </div>
</div>

<style is:inline>
  .pin-btn {
    background: #0a0a0a;
    border: 1px solid rgba(0,255,0,0.3);
    color: #00ff00;
    padding: 1rem;
    border-radius: 12px;
    font-size: 1.2rem;
    cursor: pointer;
    font-family: monospace;
    transition: all 0.1s;
  }
  .pin-btn:active { transform: scale(0.95); background: #00ff00; color: #000; }
  .tab-btn {
    background: #0a0a0a;
    border: 1px solid rgba(255,255,255,0.1);
    color: #94a3b8;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    cursor: pointer;
    font-family: monospace;
    font-size: 0.8rem;
  }
  .active-tab { border-color: #00ff00 !important; color: #00ff00 !important; }
  #chatMessages::-webkit-scrollbar, #friendChatMessages::-webkit-scrollbar { width: 4px; }
  #chatMessages::-webkit-scrollbar-thumb, #friendChatMessages::-webkit-scrollbar-thumb { background: rgba(0,255,0,0.3); border-radius: 2px; }
</style>

<script is:inline>
  var dashPin = '';
  var userRole = null;
  var SUPA_URL = 'https://sbiinkqoeoxlwzkdipmc.supabase.co';
  var SUPA_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNiaWlua3FvZW94bHd6a2RpcG1jIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzM3NzU0OTQsImV4cCI6MjA4OTM1MTQ5NH0.vN7maOOPVpEw_RY64kCdL4U2nnUJCC6sjB_MCtMTnUg';

  // PIN BUTTONS
  document.querySelectorAll('.pin-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var num = btn.getAttribute('data-num');
      if (num === 'clear') { dashPin = ''; }
      else if (num === 'enter') { checkPin(); }
      else { if (dashPin.length < 6) dashPin += num; }
      updatePinDisplay();
    });
  });

  function updatePinDisplay() {
    var shown = '';
    for (var i = 0; i < 6; i++) shown += i < dashPin.length ? '●' : '_';
    document.getElementById('pinDisplay').textContent = shown;
  }

  async function checkPin() {
    var res = await fetch('/api/admin-login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ pin: dashPin })
    });
    var data = await res.json();
    if (data.success) {
      userRole = data.role;
      document.getElementById('pinScreen').style.display = 'none';
      if (data.role === 'admin') {
        document.getElementById('dashboardContent').style.display = 'block';
        loadNotes();
      } else {
        document.getElementById('friendContent').style.display = 'block';
        loadFriendChat();
      }
    } else {
      dashPin = ''; updatePinDisplay();
      var err = document.getElementById('pinError');
      err.style.display = 'block';
      setTimeout(function() { err.style.display = 'none'; }, 2000);
    }
  }

  function resetDashboard() {
    document.getElementById('secretDashboard').style.display = 'none';
    document.getElementById('pinScreen').style.display = 'flex';
    document.getElementById('dashboardContent').style.display = 'none';
    document.getElementById('friendContent').style.display = 'none';
    dashPin = ''; userRole = null;
    updatePinDisplay();
  }

  document.getElementById('closeDashboard').addEventListener('click', resetDashboard);
  document.getElementById('closeFriend').addEventListener('click', resetDashboard);

  // TABS
  document.querySelectorAll('.tab-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active-tab'); });
      document.querySelectorAll('.tab-content').forEach(function(t) { t.style.display = 'none'; });
      btn.classList.add('active-tab');
      var tab = btn.getAttribute('data-tab');
      document.getElementById('tab-' + tab).style.display = 'block';
      if (tab === 'visitors') loadVisitors();
      if (tab === 'reviews') loadAdminReviews();
      if (tab === 'chat') loadChat();
      if (tab === 'photos') loadPhotos();
    });
  });

  // ============================================
  // NOTES
  // ============================================
  async function loadNotes() {
    var res = await fetch('/api/notes');
    var notes = await res.json();
    var list = document.getElementById('notesList');
    if (!notes.length) {
      list.innerHTML = '<p style="color:#94a3b8; font-family:monospace; font-size:0.8rem;">No notes yet.</p>';
      return;
    }
    list.innerHTML = notes.map(function(n) {
      return '<div style="background:#0a0a0a; border:1px solid rgba(0,255,0,0.2); border-radius:12px; padding:1rem; margin-bottom:1rem;">' +
        '<p style="color:#fff; font-family:monospace; font-size:0.9rem; margin-bottom:0.5rem;">' + n.content + '</p>' +
        '<div style="display:flex; justify-content:space-between;">' +
        '<span style="color:#94a3b8; font-size:0.75rem; font-family:monospace;">' + new Date(n.created_at).toLocaleString() + '</span>' +
        '<button onclick="deleteNote(\'' + n.id + '\')" style="background:transparent; border:1px solid #dc2626; color:#dc2626; padding:0.25rem 0.75rem; border-radius:8px; cursor:pointer; font-family:monospace; font-size:0.75rem;">Delete</button>' +
        '</div></div>';
    }).join('');
  }

  document.getElementById('saveNote').addEventListener('click', async function() {
    var content = document.getElementById('noteInput').value.trim();
    if (!content) return;
    await fetch('/api/notes', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ content }) });
    document.getElementById('noteInput').value = '';
    loadNotes();
  });

  async function deleteNote(id) {
    await fetch('/api/notes', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
    loadNotes();
  }

  // ============================================
  // CHAT HELPERS
  // ============================================
  function renderMessages(messages, containerId, canDelete) {
    var container = document.getElementById(containerId);
    if (!messages.length) {
      container.innerHTML = '<p style="color:#94a3b8; font-size:0.8rem; text-align:center; font-family:monospace;">No messages yet. Say something! 👋</p>';
      return;
    }
    container.innerHTML = messages.map(function(m) {
      var time = new Date(m.created_at).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
      var imgHtml = m.image_url ? '<img src="' + m.image_url + '" style="max-width:200px; border-radius:8px; margin-top:0.5rem; display:block;" />' : '';
      var deleteBtn = canDelete ? '<button onclick="deleteMessage(\'' + m.id + '\')" style="background:transparent; border:none; color:#dc2626; cursor:pointer; font-size:0.7rem; padding:0;">✕</button>' : '';
      return '<div style="margin-bottom:1rem; padding-bottom:1rem; border-bottom:1px solid rgba(255,255,255,0.05);">' +
        '<div style="display:flex; justify-content:space-between; margin-bottom:0.25rem;">' +
        '<span style="color:#00ff00; font-family:monospace; font-size:0.8rem;">' + m.sender + '</span>' +
        '<div style="display:flex; gap:0.5rem; align-items:center;">' +
        '<span style="color:#94a3b8; font-family:monospace; font-size:0.7rem;">' + time + '</span>' +
        deleteBtn + '</div></div>' +
        (m.content ? '<p style="color:#e2e8f0; font-family:monospace; font-size:0.85rem; margin:0;">' + m.content + '</p>' : '') +
        imgHtml + '</div>';
    }).join('');
    container.scrollTop = container.scrollHeight;
  }

  // ============================================
  // ADMIN CHAT
  // ============================================
  var chatPollInterval;
  var selectedImageFile = null;

  document.getElementById('chatImage').addEventListener('change', function(e) {
    var file = e.target.files[0]; if (!file) return;
    selectedImageFile = file;
    var reader = new FileReader();
    reader.onload = function(r) {
      document.getElementById('previewImg').src = r.target.result;
      document.getElementById('imagePreview').style.display = 'block';
    };
    reader.readAsDataURL(file);
  });

  function clearImagePreview() {
    selectedImageFile = null;
    document.getElementById('imagePreview').style.display = 'none';
    document.getElementById('chatImage').value = '';
  }

  async function loadChat() {
    var res = await fetch('/api/messages');
    var messages = await res.json();
    renderMessages(messages, 'chatMessages', true);
    clearInterval(chatPollInterval);
    chatPollInterval = setInterval(loadChat, 5000);
  }

  async function sendMessage(senderInputId, contentInputId, imageInputId, imagePreviewId, isAdmin) {
    var sender = document.getElementById(senderInputId).value.trim() || 'Anonymous';
    var content = document.getElementById(contentInputId).value.trim();
    var imageFile = isAdmin ? selectedImageFile : friendSelectedImage;
    if (!content && !imageFile) return;

    var imageUrl = null;
    if (imageFile) {
      var formData = new FormData();
      formData.append('file', imageFile);
      var uploadRes = await fetch('/api/photos', { method: 'POST', body: formData });
      var uploadData = await uploadRes.json();
      if (uploadData.success) {
        imageUrl = SUPA_URL + '/storage/v1/object/public/photos/' + uploadData.path;
      }
    }

    await fetch('/api/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ sender, content, image_url: imageUrl })
    });

    document.getElementById(contentInputId).value = '';
    if (isAdmin) { clearImagePreview(); loadChat(); }
    else { clearFriendImagePreview(); loadFriendChat(); }
  }

  document.getElementById('sendChat').addEventListener('click', function() {
    sendMessage('chatSender', 'chatInput', 'chatImage', 'imagePreview', true);
  });

  document.getElementById('clearChat').addEventListener('click', async function() {
    if (!confirm('Delete all messages?')) return;
    var res = await fetch('/api/messages');
    var messages = await res.json();
    for (var m of messages) {
      await fetch('/api/messages', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: m.id }) });
    }
    loadChat();
  });

  async function deleteMessage(id) {
    await fetch('/api/messages', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id }) });
    loadChat();
  }

  // ============================================
  // FRIEND CHAT
  // ============================================
  var friendChatPollInterval;
  var friendSelectedImage = null;

  document.getElementById('friendImage').addEventListener('change', function(e) {
    var file = e.target.files[0]; if (!file) return;
    friendSelectedImage = file;
    var reader = new FileReader();
    reader.onload = function(r) {
      document.getElementById('friendPreviewImg').src = r.target.result;
      document.getElementById('friendImagePreview').style.display = 'block';
    };
    reader.readAsDataURL(file);
  });

  function clearFriendImagePreview() {
    friendSelectedImage = null;
    document.getElementById('friendImagePreview').style.display = 'none';
    document.getElementById('friendImage').value = '';
  }

  async function loadFriendChat() {
    var res = await fetch('/api/messages');
    var messages = await res.json();
    renderMessages(messages, 'friendChatMessages', false);
    clearInterval(friendChatPollInterval);
    friendChatPollInterval = setInterval(loadFriendChat, 5000);
  }

  document.getElementById('sendFriendChat').addEventListener('click', function() {
    sendMessage('friendSender', 'friendInput', 'friendImage', 'friendImagePreview', false);
  });

  // ============================================
  // PHOTOS (with signed URLs for private bucket)
  // ============================================
  async function loadPhotos() {
    var res = await fetch('/api/photos');
    var photos = await res.json();
    var grid = document.getElementById('photoGrid');
    if (!photos.length || photos.error) {
      grid.innerHTML = '<p style="color:#94a3b8; font-family:monospace; font-size:0.8rem; grid-column:span 2;">No photos yet.</p>';
      return;
    }
    grid.innerHTML = photos.map(function(p) {
      return '<div style="position:relative;">' +
        '<img src="' + p.url + '" style="width:100%; border-radius:12px; border:1px solid rgba(255,255,255,0.1);" />' +
        '<button onclick="deletePhoto(\'' + p.name + '\')" style="position:absolute; top:0.5rem; right:0.5rem; background:rgba(0,0,0,0.7); border:1px solid #dc2626; color:#dc2626; border-radius:50%; width:28px; height:28px; cursor:pointer; font-size:0.8rem;">✕</button>' +
        '</div>';
    }).join('');
  }

  document.getElementById('photoUpload').addEventListener('change', async function(e) {
    var file = e.target.files[0]; if (!file) return;
    var status = document.getElementById('uploadStatus');
    status.textContent = 'Uploading...'; status.style.color = '#00ff00'; status.style.display = 'block';
    var formData = new FormData();
    formData.append('file', file);
    var res = await fetch('/api/photos', { method: 'POST', body: formData });
    var data = await res.json();
    if (data.success) {
      status.textContent = 'Uploaded! ✅';
      setTimeout(function() { status.style.display = 'none'; }, 2000);
      loadPhotos();
    } else {
      status.textContent = 'Upload failed 😞'; status.style.color = '#dc2626';
    }
  });

  async function deletePhoto(name) {
    await fetch('/api/photos', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ path: name }) });
    loadPhotos();
  }

  // ============================================
  // VISITORS
  // ============================================
  async function loadVisitors() {
    var res = await fetch('/api/visitors');
    var visitors = await res.json();
    var list = document.getElementById('visitorsList');
    if (!visitors.length) {
      list.innerHTML = '<p style="color:#94a3b8; font-family:monospace; font-size:0.8rem;">No visitors yet.</p>';
      return;
    }
    list.innerHTML = visitors.map(function(v) {
      return '<div style="background:#0a0a0a; border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:1rem; margin-bottom:0.75rem; display:flex; justify-content:space-between; align-items:center;">' +
        '<div><p style="color:#fff; font-family:monospace; font-size:0.9rem;">📍 ' + (v.city||'Unknown') + ', ' + (v.country||'Unknown') + '</p>' +
        '<p style="color:#94a3b8; font-family:monospace; font-size:0.75rem;">' + (v.device||'') + ' · ' + (v.browser||'') + '</p></div>' +
        '<span style="color:#94a3b8; font-family:monospace; font-size:0.7rem;">' + new Date(v.created_at).toLocaleString() + '</span>' +
        '</div>';
    }).join('');
  }

  // ============================================
  // REVIEWS
  // ============================================
  async function loadAdminReviews() {
    var res = await fetch(SUPA_URL + '/rest/v1/reviews?order=created_at.desc', {
      headers: { 'apikey': SUPA_KEY, 'Authorization': 'Bearer ' + SUPA_KEY }
    });
    var reviews = await res.json();
    var list = document.getElementById('adminReviewsList');
    if (!reviews.length) {
      list.innerHTML = '<p style="color:#94a3b8; font-family:monospace; font-size:0.8rem;">No reviews.</p>';
      return;
    }
    list.innerHTML = reviews.map(function(r) {
      return '<div style="background:#0a0a0a; border:1px solid rgba(255,255,255,0.1); border-radius:12px; padding:1rem; margin-bottom:0.75rem;">' +
        '<div style="display:flex; justify-content:space-between; margin-bottom:0.5rem;">' +
        '<span style="color:#fff; font-family:monospace;">' + r.name + '</span>' +
        '<button onclick="deleteReview(\'' + r.id + '\')" style="background:transparent; border:1px solid #dc2626; color:#dc2626; padding:0.25rem 0.75rem; border-radius:8px; cursor:pointer; font-family:monospace; font-size:0.75rem;">Delete</button>' +
        '</div>' +
        '<p style="color:#f59e0b; font-family:monospace;">' + '★'.repeat(r.rating) + '☆'.repeat(5-r.rating) + '</p>' +
        '<p style="color:#94a3b8; font-family:monospace; font-size:0.85rem;">' + r.comment + '</p>' +
        '</div>';
    }).join('');
  }

  async function deleteReview(id) {
    await fetch(SUPA_URL + '/rest/v1/reviews?id=eq.' + id, {
      method: 'DELETE',
      headers: { 'apikey': SUPA_KEY, 'Authorization': 'Bearer ' + SUPA_KEY }
    });
    loadAdminReviews();
  }
</script>