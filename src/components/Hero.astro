---
import type { HeroProps } from "@types";
type Props = HeroProps;
const { name, specialty, summary, email } = Astro.props;
---

<section class="hero-section" id="hero">
  <div class="hero-content">
    <div class="avatar-wrapper" id="avatar3d">
      <div class="avatar-glow"></div>
      <img src="/AvatarMaker.png" alt={name} id="avatarImg" />
    </div>

    <p class="specialty animate-in" style="animation-delay:0.1s">{specialty}</p>
    <h1 class="hero-name animate-in" style="animation-delay:0.2s">{name}</h1>
    <p class="hero-summary animate-in" style="animation-delay:0.3s">{summary}</p>

    <a href={`mailto:${email}`} class="cta-btn animate-in" style="animation-delay:0.4s">
      Get in Touch ✉️
    </a>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem;
  }

  /* 3D Avatar */
  .avatar-wrapper {
    position: relative;
    width: 160px;
    height: 160px;
    margin-bottom: 1.75rem;
    transform-style: preserve-3d;
    transition: transform 0.1s ease-out;
    cursor: pointer;
  }

  .avatar-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    border: 2px solid rgba(37,99,235,0.6);
    box-shadow:
      0 0 30px rgba(37,99,235,0.5),
      0 0 80px rgba(37,99,235,0.2),
      0 20px 60px rgba(0,0,0,0.5);
    display: block;
    position: relative;
    z-index: 2;
  }

  .avatar-glow {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(37,99,235,0.4) 0%, transparent 70%);
    z-index: 1;
    animation: pulseGlow 3s ease-in-out infinite;
    filter: blur(8px);
  }

  @keyframes pulseGlow {
    0%, 100% { transform: scale(1); opacity: 0.7; }
    50% { transform: scale(1.15); opacity: 1; }
  }

  /* Floating animation */
  @keyframes float {
    0%, 100% { transform: translateY(0px) rotateX(0deg); }
    50% { transform: translateY(-12px) rotateX(3deg); }
  }

  .avatar-wrapper {
    animation: float 4s ease-in-out infinite;
  }

  /* Slide in animation */
  .animate-in {
    opacity: 0;
    transform: translateY(24px);
    animation: slideUp 0.7s ease forwards;
  }

  @keyframes slideUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .specialty {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #60a5fa;
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .hero-name {
    font-family: var(--font-serif);
    font-size: clamp(5rem, 15vw, 10rem);
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -3px;
    line-height: 1;
    margin-bottom: 1.5rem;
    text-shadow: 0 0 80px rgba(37,99,235,0.6);
  }

  .hero-summary {
    max-width: 420px;
    font-size: 1rem;
    color: #94a3b8;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .cta-btn {
    display: inline-block;
    padding: 0.875rem 2.5rem;
    border-radius: 9999px;
    background: #2563eb;
    color: #fff;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s;
    box-shadow: 0 0 20px rgba(37,99,235,0.4);
  }

  .cta-btn:hover {
    opacity: 0.85;
    box-shadow: 0 0 35px rgba(37,99,235,0.7);
    transform: translateY(-2px);
  }
</style>

<script>
  // 3D tilt effect on mouse move
  const avatar = document.getElementById('avatar3d') as HTMLElement;

  document.addEventListener('mousemove', (e) => {
    const rect = avatar.getBoundingClientRect();
    const centerX = rect.left + rect.width / 2;
    const centerY = rect.top + rect.height / 2;
    const deltaX = (e.clientX - centerX) / window.innerWidth;
    const deltaY = (e.clientY - centerY) / window.innerHeight;

    const rotateX = deltaY * -20;
    const rotateY = deltaX * 20;

    avatar.style.transform = `perspective(600px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.05)`;
  });

  document.addEventListener('mouseleave', () => {
    avatar.style.transform = 'perspective(600px) rotateX(0deg) rotateY(0deg) scale(1)';
  });
</script>